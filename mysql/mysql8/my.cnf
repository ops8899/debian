[client]
password = #PASSWORD#
port = 61786
socket = /tmp/mysql.sock

[mysqldump]
quick
max_allowed_packet = 64M
password = #PASSWORD#

[mysqld]
# 调整为512K，避免复杂查询出错
thread_stack = 512K

# ---------- 基础配置 ----------
server-id = 1
port = 61786
datadir = /data/mysql
socket = /tmp/mysql.sock

lower_case_table_names = 1

# ---------- 字符集配置 ----------
character-set-server = utf8mb4
collation-server = utf8mb4_0900_ai_ci

# ---------- 认证和安全 ----------
authentication_policy = '*'
tls_version = TLSv1.2
skip-name-resolve

# ---------- GTID和复制配置 ----------
gtid-mode = ON
enforce-gtid-consistency = 1
log_replica_updates = 1
replica_compressed_protocol = ON
replica_skip_errors = all

# ---------- Binlog配置 ----------
log_bin = mysql-bin
binlog_format = row
# 调整为256K，以支持较大事务
binlog_cache_size = 256K

binlog_expire_logs_seconds = 5184000

# ---------- 内存相关配置 ----------
# 假设服务器内存为8G，设置为4G
innodb_buffer_pool_size = 2G

# 内存相关参数调整
key_buffer_size = 128M
max_heap_table_size = 64M
tmp_table_size = 64M
join_buffer_size = 2M
sort_buffer_size = 2M
read_buffer_size = 1M
read_rnd_buffer_size = 1M
myisam_sort_buffer_size = 16M

# ---------- 连接数设置 ----------
max_connections = 200
thread_cache_size = 64
wait_timeout = 28800
interactive_timeout = 28800

# ---------- 存储引擎配置 ----------
default_storage_engine = InnoDB
innodb_file_per_table = 1
innodb_flush_method = O_DIRECT
innodb_autoinc_lock_mode = 2

# 缓存相关配置 - 调整为更合理的值
performance_schema_max_table_instances = 2000
table_definition_cache = 2000
table_open_cache = 2000

# ---------- InnoDB配置 ----------
# 调整为1GB
innodb_redo_log_capacity = 1073741824
innodb_log_buffer_size = 32M
innodb_data_file_path = ibdata1:10M:autoextend
innodb_temp_data_file_path = ibtmp1:12M:autoextend
innodb_flush_log_at_trx_commit = 1
innodb_lock_wait_timeout = 50
innodb_max_dirty_pages_pct = 90

# IO线程数配置 - 假设8核CPU
innodb_read_io_threads = 4
innodb_write_io_threads = 4

# ---------- 查询相关 ----------
max_allowed_packet = 64M

sql-mode = "STRICT_TRANS_TABLES,NO_ENGINE_SUBSTITUTION,NO_ZERO_DATE,NO_ZERO_IN_DATE,ERROR_FOR_DIVISION_BY_ZERO"
explicit_defaults_for_timestamp = true

# ---------- 慢查询日志 ----------
slow_query_log = 1
long_query_time = 3
# slow_query_log_file = /data/mysql/mysql-slow.log

[mysql]
no-auto-rehash

[myisamchk]
key_buffer_size = 128M
sort_buffer_size = 4M
read_buffer = 4M
write_buffer = 4M

[mysqlhotcopy]
interactive-timeout

# ---------- 监控建议 ----------
# 重要监控指标：
# 1. innodb_buffer_pool_usage：缓冲池使用率
# 2. Threads_connected/max_connections：连接数使用率
# 3. Slow queries：慢查询数量
# 4. InnoDB read/write I/O：IO负载情况
# 5. Memory usage：内存使用情况
# 6. Swap usage：是否发生交换
# 7. Table_locks_waited：表锁等待情况
# 8. Innodb_row_lock_waits：行锁等待情况

# ---------- 注意事项 ----------
# 1. 以上参数基于8G内存、8核CPU的服务器配置
# 2. 实际使用时需要根据具体硬件配置和业务场景调整
# 3. 建议在测试环境验证后再应用到生产环境
# 4. 修改参数后需要重启MySQL服务
# 5. 建议通过监控工具持续观察系统运行状况
# 6. 定期检查错误日志和慢查询日志
# 7. 定期进行ANALYZE TABLE和OPTIMIZE TABLE操作
# 8. 注意观察系统swap使用情况
