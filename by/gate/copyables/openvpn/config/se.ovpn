dev tun
proto tcp
#remote 127.0.0.1 1194
cipher AES-128-CBC
data-ciphers AES-256-GCM:AES-128-GCM:CHACHA20-POLY1305:AES-128-CBC
auth SHA1

resolv-retry infinite
nobind
persist-key
persist-tun
client
verb 3

auth-user-pass

