client
dev tun
proto tcp
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server
auth SHA256
cipher AES-256-GCM
ignore-unknown-option block-outside-dns block-ipv6
verb 3
ca /root/openvpn/config/client_ca.crt
tls-crypt /root/openvpn/config/client_tc.key
cert /root/openvpn/config/client_cert.crt
key /root/openvpn/config/client_key.key
